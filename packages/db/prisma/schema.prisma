datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Document {
  id               String     @id @default(cuid())
  ownerId          String
  title            String
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  latestRevisionId String?    @unique
  latestRevision   Revision?  @relation("LatestRevision", fields: [id, latestRevisionId], references: [documentId, id])

  revisions        Revision[] @relation("DocumentRevisions")

  @@index([ownerId])
}

model Revision {
  id             String    @id @default(cuid())
  documentId     String
  createdAt      DateTime  @default(now())
  revisionNumber Int
  content        String
  createdBy      String

  document       Document  @relation("DocumentRevisions", fields: [documentId], references: [id], onDelete: Cascade)
  latestOf       Document? @relation("LatestRevision")

  @@unique([documentId, id])
  @@unique([documentId, revisionNumber])
  @@index([documentId, createdAt])
}
